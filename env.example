FROM_EMAIL=
FROM_EMAIL_PASS=
ADMIN_EMAIL=
NEXT_PUBLIC_SITE_URL=

# Google Analytics 4 — MUST be NEXT_PUBLIC_* and set before `pnpm build` (e.g. Vercel env + redeploy)
# Admin → Data streams → Web → Measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Aliases also work: NEXT_PUBLIC_GTAG_ID or NEXT_PUBLIC_GOOGLE_ANALYTICS_ID
# Local dev: set NEXT_PUBLIC_GA_ENABLE_IN_DEV=true to send test hits
NEXT_PUBLIC_GA_ENABLE_IN_DEV=

# Google Search Console — OPTIONAL HTML-tag verification token (the bare value only,
# NOT the full "google-site-verification=..." string). Leave empty if using DNS/Domain
# verification. Search Console → Settings → Ownership verification → HTML tag.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
